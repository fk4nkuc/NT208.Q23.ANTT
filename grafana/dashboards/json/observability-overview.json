    {
      "id": 4,
      "type": "stat",
      "title": "alertmanager",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"alertmanager\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
